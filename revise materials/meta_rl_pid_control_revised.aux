\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Quantitative characterization of the optimization ceiling effect. $G_{\mathrm  {RL}}$ = platform-level RL gain rate; $\mathrm  {CV}_e$ = coefficient of variation of baseline joint errors; Max $G_{\mathrm  {RL},j}$ = highest per-joint gain; Joints with $G_{\mathrm  {RL},j}<0$ = joints where RL slightly degrades performance.\relax }}{27}{table.0.10}\protected@file@percent }
\newlabel{tab:ceiling_quantification}{{10}{27}{Quantitative characterization of the optimization ceiling effect. $G_{\mathrm {RL}}$ = platform-level RL gain rate; $\mathrm {CV}_e$ = coefficient of variation of baseline joint errors; Max $G_{\mathrm {RL},j}$ = highest per-joint gain; Joints with $G_{\mathrm {RL},j}<0$ = joints where RL slightly degrades performance.\relax }{table.0.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces {\color  {blue}Optimization ceiling effect: per-joint RL gain rate ($G_{\mathrm  {RL},j}$) vs.\ meta-learning baseline error ($e_{\mathrm  {base},j}$) across 21 joints of two robot platforms. The shaded region ($G_{\mathrm  {RL}} < 5\%$) indicates the ``ceiling zone'' where RL provides minimal additional benefit. Franka J2 (shoulder pitch, $e_{\mathrm  {base}}=12.36^\circ $) is the sole joint exhibiting dramatic RL improvement ($G_{\mathrm  {RL}}=80.4\%$), while most joints cluster in the ceiling zone regardless of their absolute error magnitude. Spearman rank correlation: $\rho _s = 0.38$, $n = 21$.}\relax }}{28}{figure.0.7}\protected@file@percent }
\newlabel{fig:ceiling_scatter}{{7}{28}{\rev {Optimization ceiling effect: per-joint RL gain rate ($G_{\mathrm {RL},j}$) vs.\ meta-learning baseline error ($e_{\mathrm {base},j}$) across 21 joints of two robot platforms. The shaded region ($G_{\mathrm {RL}} < 5\%$) indicates the ``ceiling zone'' where RL provides minimal additional benefit. Franka J2 (shoulder pitch, $e_{\mathrm {base}}=12.36^\circ $) is the sole joint exhibiting dramatic RL improvement ($G_{\mathrm {RL}}=80.4\%$), while most joints cluster in the ceiling zone regardless of their absolute error magnitude. Spearman rank correlation: $\rho _s = 0.38$, $n = 21$.}\relax }{figure.0.7}{}}
